<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MVP Love</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        brand: {
                            950: '#0f172a',
                            900: '#1e1b4b',
                            800: '#312e81',
                            700: '#3730a3',
                            600: '#4338ca',
                            500: '#6366f1',
                        }
                    }
                }
            }
        }
    </script>
    <style>
        .htmx-indicator { display: none; }
        .htmx-request .htmx-indicator, .htmx-request.htmx-indicator { display: flex; }
        .htmx-request #mvp-results { opacity: 0.5; transition: opacity 0.2s; }
        [x-cloak] { display: none !important; }
    </style>
    <script src="https://unpkg.com/htmx.org@1.9.12" defer></script>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body class="bg-slate-50 min-h-screen flex flex-col text-slate-800">

    <!-- Top navigation -->
    <nav class="bg-gradient-to-r from-indigo-950 via-indigo-900 to-violet-900 text-white shadow-xl sticky top-0 z-50">
        <div class="max-w-screen-2xl mx-auto px-4 py-3 flex items-center justify-between">
            <a asp-controller="Mvp" asp-action="Index" class="flex items-center gap-3 group">
                <div class="w-9 h-9 rounded-lg flex items-center justify-center group-hover:scale-110 transition-transform">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32" width="36" height="36">
                        <path d="M16 27 C14 25 4 19 4 12 C4 7.6 7.2 5 11 5 C13.2 5 15 6.2 16 8 C17 6.2 18.8 5 21 5 C24.8 5 28 7.6 28 12 C28 19 18 25 16 27 Z" fill="#dc2626"/>
                        <text x="16" y="14" text-anchor="middle" dominant-baseline="middle" fill="white" font-family="Arial,sans-serif" font-weight="bold" font-size="8">MVP</text>
                    </svg>
                </div>
                <div>
                    <div class="font-bold text-base leading-tight tracking-tight">MVP Love</div>
                    <div class="text-xs text-indigo-300 leading-tight">Microsoft MVP Browser</div>
                </div>
            </a>
            <div class="flex items-center gap-2 text-sm">
                <a asp-controller="Mvp" asp-action="Index" class="px-3 py-1.5 rounded-md text-indigo-200 hover:text-white hover:bg-white/10 transition-colors">Browse</a>
                <a href="https://github.com/edandersen/mvplove" target="_blank" rel="noopener noreferrer" class="px-3 py-1.5 rounded-md text-indigo-200 hover:text-white hover:bg-white/10 transition-colors flex items-center gap-1.5">
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                        <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"/>
                    </svg>
                    GitHub
                </a>
            </div>
        </div>
    </nav>

    <!-- Page content -->
    <main class="flex-1">
        @RenderBody()
    </main>

    <!-- Footer -->
    <footer class="bg-indigo-950 text-indigo-300 text-sm py-4 mt-8">
        <div class="max-w-screen-2xl mx-auto px-4 flex items-center justify-between">
            <a href="https://youtube.com/edandersen" target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors">
                Made with ❤️ by Ed Andersen
            </a>
            <span class="text-xs text-indigo-500">Powered by .NET 10 · ASP.NET Core MVC · HTMX · Tailwind CSS</span>
        </div>
    </footer>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
