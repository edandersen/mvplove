@model HomeDashboardViewModel
@using mvcmcpmvp.Models

@{
    ViewData["Title"] = "MVP Dashboard";
}

@* Hero *@
<div class="bg-gradient-to-br from-blue-950 via-blue-900 to-blue-700 text-white py-10 px-4">
    <div class="max-w-screen-xl mx-auto">
        <h1 class="text-3xl font-bold tracking-tight">Microsoft MVP Dashboard</h1>
        <p class="text-blue-300 text-sm mt-1">@Model.TotalCount profiles · highlights from across the community</p>
    </div>
</div>

@* Three-column dashboard *@
<div class="max-w-screen-xl mx-auto px-4 py-8">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">

        @* Column 1 — Longest Tenured *@
        <div>
            <div class="flex items-center gap-2 mb-4">
                <span class="text-2xl">🏆</span>
                <div>
                    <h2 class="text-lg font-bold text-slate-800 leading-tight">Longest Tenured</h2>
                    <p class="text-xs text-slate-400">Most years in the MVP program</p>
                </div>
            </div>
            <div class="flex flex-col gap-3">
                @foreach (var mvp in Model.LongestTenured)
                {
                    @await Html.PartialAsync("_MvpCard", mvp)
                }
            </div>
        </div>

        @* Column 2 — Most Languages *@
        <div>
            <div class="flex items-center gap-2 mb-4">
                <span class="text-2xl">🌍</span>
                <div>
                    <h2 class="text-lg font-bold text-slate-800 leading-tight">Most Languages</h2>
                    <p class="text-xs text-slate-400">MVPs who speak the most languages</p>
                </div>
            </div>
            <div class="flex flex-col gap-3">
                @foreach (var mvp in Model.MostLanguages)
                {
                    @await Html.PartialAsync("_MvpCard", mvp)
                }
            </div>
        </div>

        @* Column 3 — New MVPs *@
        <div>
            <div class="flex items-center gap-2 mb-4">
                <span class="text-2xl">✨</span>
                <div>
                    <h2 class="text-lg font-bold text-slate-800 leading-tight">New MVPs</h2>
                    <p class="text-xs text-slate-400">Just joined — 1 year in the program</p>
                </div>
            </div>
            <div class="flex flex-col gap-3">
                @foreach (var mvp in Model.NewMvps)
                {
                    @await Html.PartialAsync("_MvpCard", mvp)
                }
            </div>
        </div>

    </div>
</div>
