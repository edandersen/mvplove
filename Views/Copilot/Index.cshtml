@model bool

@{
    ViewData["Title"] = "Copilot";
}

@if (!Model)
{
    <p class="text-slate-600 p-4">Set up OpenAI API key</p>
}
else
{
    <div class="flex items-start justify-center h-[calc(100vh-64px)] bg-slate-100 py-8 px-4">
        <div class="flex flex-col w-full max-w-2xl h-full bg-white rounded-2xl shadow-lg border border-slate-200 overflow-hidden">
            <div class="bg-gradient-to-r from-blue-950 via-blue-900 to-blue-700 px-6 py-4">
                <h1 class="text-lg font-bold text-white tracking-tight">MVP Copilot</h1>
                <p class="text-xs text-blue-300">Your AI assistant for Microsoft MVP data</p>
            </div>
            <div id="agui-messages" class="flex-1 overflow-y-auto px-6 py-6 space-y-3">
            </div>
            <form id="agui-form" class="border-t border-slate-200 px-4 py-3 flex gap-2">
                <input id="agui-input" type="text" placeholder="How can I help you with MVPs today?"
                       class="flex-1 rounded-full border border-slate-300 px-5 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
                <button id="agui-send" type="submit"
                        class="rounded-full bg-blue-600 px-5 py-2.5 text-sm font-medium text-white hover:bg-blue-700 disabled:opacity-50 transition-colors">
                    Send
                </button>
            </form>
        </div>
    </div>

    <style>
        .prose-chat h1, .prose-chat h2, .prose-chat h3 { font-weight: 700; margin-top: 0.75em; margin-bottom: 0.25em; }
        .prose-chat h1 { font-size: 1.25em; }
        .prose-chat h2 { font-size: 1.1em; }
        .prose-chat h3 { font-size: 1em; }
        .prose-chat p { margin: 0.4em 0; }
        .prose-chat ul, .prose-chat ol { margin: 0.4em 0; padding-left: 1.5em; }
        .prose-chat ul { list-style: disc; }
        .prose-chat ol { list-style: decimal; }
        .prose-chat li { margin: 0.15em 0; }
        .prose-chat code { background: rgba(0,0,0,0.06); padding: 0.15em 0.35em; border-radius: 0.25em; font-size: 0.9em; }
        .prose-chat pre { background: #1e293b; color: #e2e8f0; padding: 0.75em 1em; border-radius: 0.5em; overflow-x: auto; margin: 0.5em 0; }
        .prose-chat pre code { background: none; padding: 0; color: inherit; }
        .prose-chat a { color: #2563eb; text-decoration: underline; }
        .prose-chat blockquote { border-left: 3px solid #cbd5e1; padding-left: 0.75em; color: #64748b; margin: 0.5em 0; }
        .prose-chat table { border-collapse: collapse; margin: 0.5em 0; width: 100%; }
        .prose-chat th, .prose-chat td { border: 1px solid #cbd5e1; padding: 0.35em 0.6em; text-align: left; }
        .prose-chat th { background: rgba(0,0,0,0.04); font-weight: 600; }
        .prose-chat strong { font-weight: 700; }
        .prose-chat > *:first-child { margin-top: 0; }
        .prose-chat > *:last-child { margin-bottom: 0; }
    </style>
    <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
    <script src="~/js/agui-client.js"></script>
}

