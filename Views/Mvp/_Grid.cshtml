@model MvpGridViewModel

@if (Model.Results.Count == 0)
{
    <div class="flex flex-col items-center justify-center py-24 text-center">
        <div class="text-6xl mb-4">🔍</div>
        <h3 class="text-xl font-semibold text-slate-700 mb-2">No MVPs found</h3>
        <p class="text-slate-400 text-sm">Try adjusting your search or clearing filters</p>
        <a href="/Mvp" class="mt-4 px-4 py-2 bg-indigo-600 text-white rounded-lg text-sm hover:bg-indigo-700 transition-colors">Clear filters</a>
    </div>
}
else
{
    @* Card grid *@
    <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 2xl:grid-cols-4 gap-4 mb-6">
        @foreach (var mvp in Model.Results)
        {
            <a href="/Mvp/Detail/@mvp.Id"
               class="bg-white rounded-2xl shadow-sm border border-slate-100 p-5 flex flex-col gap-3 hover:shadow-md hover:-translate-y-0.5 transition-all duration-150 group cursor-pointer">

                @* Top: avatar + name *@
                <div class="flex items-start gap-3">
                    @if (!string.IsNullOrEmpty(mvp.ProfilePictureUrl))
                    {
                        <img src="@mvp.ProfilePictureUrl"
                             alt="@mvp.Name"
                             class="w-14 h-14 rounded-full object-cover flex-shrink-0 border-2 border-slate-100"
                             onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
                        <div class="w-14 h-14 rounded-full bg-gradient-to-br from-indigo-500 to-violet-600 flex-shrink-0 items-center justify-center text-white font-bold text-lg" style="display:none">
                            @mvp.Initials
                        </div>
                    }
                    else
                    {
                        <div class="w-14 h-14 rounded-full bg-gradient-to-br from-indigo-500 to-violet-600 flex-shrink-0 flex items-center justify-center text-white font-bold text-lg">
                            @mvp.Initials
                        </div>
                    }
                    <div class="flex-1 min-w-0">
                        <div class="font-semibold text-slate-800 group-hover:text-indigo-700 transition-colors leading-snug truncate">@mvp.Name</div>
                        <div class="text-xs text-slate-500 mt-0.5 line-clamp-2 leading-snug">@mvp.Headline</div>
                    </div>
                </div>

                @* Award badges *@
                @if (mvp.AwardCategory.Count > 0)
                {
                    <div class="flex flex-wrap gap-1.5">
                        @foreach (var award in mvp.AwardCategory.Take(2))
                        {
                            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium @MvpProfile.AwardBadgeClasses(award)">
                                @award
                            </span>
                        }
                        @if (mvp.AwardCategory.Count > 2)
                        {
                            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-slate-100 text-slate-500">
                                +@(mvp.AwardCategory.Count - 2)
                            </span>
                        }
                    </div>
                }

                @* Footer: country + years *@
                <div class="flex items-center gap-3 text-xs text-slate-400 mt-auto pt-2 border-t border-slate-50">
                    @if (!string.IsNullOrEmpty(mvp.Country))
                    {
                        <span class="flex items-center gap-1 truncate">
                            <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                            </svg>
                            <span class="truncate">@mvp.Country</span>
                        </span>
                    }
                    @if (mvp.YearsInProgram.HasValue && mvp.YearsInProgram > 0)
                    {
                        <span class="flex items-center gap-1 flex-shrink-0">
                            <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20">
                                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                            </svg>
                            @mvp.YearsInProgram yr@(mvp.YearsInProgram != 1 ? "s" : "")
                        </span>
                    }
                </div>
            </a>
        }
    </div>

    @* Pagination *@
    @if (Model.TotalPages > 1)
    {
        <div class="flex items-center justify-center gap-1 py-2">
            @if (Model.Page > 1)
            {
                <button class="flex items-center gap-1 px-3 py-2 text-sm text-slate-600 bg-white border border-slate-200 rounded-lg hover:bg-slate-50 transition-colors"
                        hx-get="/Mvp/Grid?page=@(Model.Page - 1)"
                        hx-target="#mvp-results"
                        hx-include="#filter-form">
                    ← Prev
                </button>
            }

            @{
                int start = Math.Max(1, Model.Page - 2);
                int end   = Math.Min(Model.TotalPages, Model.Page + 2);
            }
            @if (start > 1)
            {
                <button class="px-3 py-2 text-sm text-slate-600 bg-white border border-slate-200 rounded-lg hover:bg-slate-50 transition-colors"
                        hx-get="/Mvp/Grid?page=1" hx-target="#mvp-results" hx-include="#filter-form">1</button>
                @if (start > 2) { <span class="px-1 text-slate-400">…</span> }
            }

            @for (int p = start; p <= end; p++)
            {
                var pageNum = p;
                <button class="px-3 py-2 text-sm rounded-lg border transition-colors @(pageNum == Model.Page ? "bg-indigo-600 text-white border-indigo-600 font-semibold" : "text-slate-600 bg-white border-slate-200 hover:bg-slate-50")"
                        hx-get="/Mvp/Grid?page=@pageNum"
                        hx-target="#mvp-results"
                        hx-include="#filter-form">
                    @pageNum
                </button>
            }

            @if (end < Model.TotalPages)
            {
                @if (end < Model.TotalPages - 1) { <span class="px-1 text-slate-400">…</span> }
                <button class="px-3 py-2 text-sm text-slate-600 bg-white border border-slate-200 rounded-lg hover:bg-slate-50 transition-colors"
                        hx-get="/Mvp/Grid?page=@Model.TotalPages" hx-target="#mvp-results" hx-include="#filter-form">@Model.TotalPages</button>
            }

            @if (Model.Page < Model.TotalPages)
            {
                <button class="flex items-center gap-1 px-3 py-2 text-sm text-slate-600 bg-white border border-slate-200 rounded-lg hover:bg-slate-50 transition-colors"
                        hx-get="/Mvp/Grid?page=@(Model.Page + 1)"
                        hx-target="#mvp-results"
                        hx-include="#filter-form">
                    Next →
                </button>
            }
        </div>
        <p class="text-center text-xs text-slate-400 mt-1">Page @Model.Page of @Model.TotalPages · @Model.TotalResults total</p>
    }
}
