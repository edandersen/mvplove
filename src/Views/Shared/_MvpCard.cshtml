@model MvpProfile
@using mvcmcpmvp.Models

<a href="/Mvp/Detail/@Model.Id"
   class="bg-white rounded-2xl shadow-sm border border-slate-100 p-5 flex flex-col gap-3 hover:shadow-md hover:-translate-y-0.5 transition-all duration-150 group cursor-pointer">

    @* Avatar + name *@
    <div class="flex items-start gap-3">
        @if (!string.IsNullOrEmpty(Model.ProfilePictureUrl))
        {
            <img src="@Model.ProfilePictureUrl"
                 alt="@Model.Name"
                 class="w-14 h-14 rounded-full object-cover flex-shrink-0 border-2 border-slate-100"
                 onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
            <div class="w-14 h-14 rounded-full bg-gradient-to-br from-indigo-500 to-blue-600 flex-shrink-0 items-center justify-center text-white font-bold text-lg" style="display:none">
                @Model.Initials
            </div>
        }
        else
        {
            <div class="w-14 h-14 rounded-full bg-gradient-to-br from-indigo-500 to-blue-600 flex-shrink-0 flex items-center justify-center text-white font-bold text-lg">
                @Model.Initials
            </div>
        }
        <div class="flex-1 min-w-0">
            <div class="font-semibold text-slate-800 group-hover:text-indigo-700 transition-colors leading-snug truncate">@Model.Name</div>
            <div class="text-xs text-slate-500 mt-0.5 line-clamp-2 leading-snug">@Model.Headline</div>
        </div>
    </div>

    @* Award badges *@
    @if (Model.AwardCategory.Count > 0)
    {
        <div class="flex flex-wrap gap-1.5">
            @foreach (var award in Model.AwardCategory.Take(2))
            {
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium @MvpProfile.AwardBadgeClasses(award)">
                    @award
                </span>
            }
            @if (Model.AwardCategory.Count > 2)
            {
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-slate-100 text-slate-500">
                    +@(Model.AwardCategory.Count - 2)
                </span>
            }
        </div>
    }

    @* Footer: country + years *@
    <div class="flex items-center gap-3 text-xs text-slate-400 mt-auto pt-2 border-t border-slate-50">
        @if (!string.IsNullOrEmpty(Model.Country))
        {
            <span class="flex items-center gap-1 truncate">
                <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
                <span class="truncate">@Model.Country</span>
            </span>
        }
        @if (Model.YearsInProgram.HasValue && Model.YearsInProgram > 0)
        {
            <span class="flex items-center gap-1 flex-shrink-0">
                <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                </svg>
                @Model.YearsInProgram yr@(Model.YearsInProgram != 1 ? "s" : "")
            </span>
        }
        @if (Model.Languages.Count > 0)
        {
            <span class="flex items-center gap-1 flex-shrink-0 ml-auto">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 016.412 9m6.088 9h7M11 21l5-10 5 10M12.751 5C11.783 10.77 8.07 15.61 3 18.129"/>
                </svg>
                @Model.Languages.Count lang@(Model.Languages.Count != 1 ? "s" : "")
            </span>
        }
    </div>
</a>
